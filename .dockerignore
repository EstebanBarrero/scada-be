data/*.db-shm
data/*.db-wal
data/*.lock
data/raw_alarms.csv

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# Env file (secrets — never bake into image)
.env

# Docs
*.md
